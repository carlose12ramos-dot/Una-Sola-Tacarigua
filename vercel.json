{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "git lfs pull && npm ci --ignore-scripts",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/{.env,.env.production}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    },
    {
      "source": "/historia.html",
      "destination": "/historia.html"
    },
    {
      "source": "/cultura.html",
      "destination": "/cultura.html"
    },
    {
      "source": "/biblioteca.html",
      "destination": "/biblioteca.html"
    },
    {
      "source": "/geografia.html",
      "destination": "/geografia.html"
    },
    {
      "source": "/sociedad.html",
      "destination": "/sociedad.html"
    },
    {
      "source": "/nosotros.html",
      "destination": "/nosotros.html"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
